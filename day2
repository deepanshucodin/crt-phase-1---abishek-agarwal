//problem no. 5- continue statement 
// print 1 to n and avoid those number which are divisible by 3
#include <iostream>
using namespace std;
int main(){
    int n;
    cin>> n;
    
    for (int i=1; i<=n; i++){
        if(i% 3 ==0){
            continue;
        }
        cout<< i<< " ";
    }
   cout << "\n";
   return 0;
}




//problem no. 6- break statement 
// we have to add a no. unti we gwt a negative number
#include <iostream>
using namespace std;
int main(){
    int n;
    int sum=0;
    while (true){
      cin>>n;
      if(n<0){
          break;
          
      }
      sum=sum+n;
      
      
    }
    cout << sum ;
    return 0;
}
 





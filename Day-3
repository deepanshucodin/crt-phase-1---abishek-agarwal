//problem no. 1 --
//print 1 to 10 using a for loop
#include<iostream>
using namespace std;
int main(){
    
    for(i=1,1<=10,i++){
        cout<<i<<" ";
    }
    cout<<"\n";
    return 0;
}




//problem no. 2 --
//print 10 to 1 using a for loop
#include<iostream>
using namespace std;
int main(){
    
    for(int i=10;i>=1;i--){
        cout<<i<<" ";
    }
    cout<<"\n";
    return 0;
}





//problem no. 3 --
//print 1 to 10 using a while loop
#include<iostream>
using namespace std;
int main(){
    int i =1;
    while(i<=10){
        cout<<i<<" ";
        i++;
    }
    cout<<"\n";
    return 0;
 
}





//problem no. 4 --
//print 10 to 1 using a while loop
#include<iostream>
using namespace std;
int main(){
    int i =10;
    while(i>=1){
        cout<<i<<" ";
        i--;
    }
    cout<<"\n";
    return 0;
 
}




